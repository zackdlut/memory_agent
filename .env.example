# LLM / Embedding endpoint (Ollama, OpenAI/Anthropic compatible base).
# The system uses the Ollama native API (/api/chat, /api/embeddings).
ANTHROPIC_BASE_URL=http://10.67.34.44:11434
ANTHROPIC_AUTH_TOKEN=ollam
ANTHROPIC_MODEL=qwen3.5:9b

# Optional explicit overrides (fall back to the ANTHROPIC_* values above).
# LLM_BASE_URL=http://10.67.34.44:11434
# CHAT_MODEL=qwen3.5:9b
EMBED_MODEL=nomic-embed-text:latest
EMBED_DIM=768

# Storage location for FAISS / SQLite / graph snapshots.
DATA_DIR=./data

# Server
HOST=0.0.0.0
PORT=8000
